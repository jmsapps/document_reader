AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<endpoint>.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_API_KEY=<api_key>

AZURE_STORAGE_BLOB_ENDPOINT=https://<storage-account>.blob.core.windows.net
AZURE_STORAGE_BLOB_API_KEY=<storage-account-key>

AZURE_AI_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
AZURE_AI_SEARCH_API_KEY=<search-api-key>

AZURE_EMBEDDING_PROVIDER=<azure_openai/azure_ai_vision/foundry>

AZURE_FOUNDRY_ENDPOINT=https://<foundry-resource>.services.ai.azure.com
AZURE_FOUNDRY_API_KEY=<foundry-api-key>

AZURE_OPENAI_ENDPOINT=https://<openai-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<openai-api-key>
AZURE_OPENAI_API_VERSION=v1
AZURE_OPENAI_INTERPRET_DEPLOYMENT=<interpret-deployment-name>
AZURE_OPENAI_VERBALIZATION_DEPLOYMENT=<verbalization-deployment-name>
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=<embedding-deployment-name>
AZURE_OPENAI_EMBEDDING_DIMENSIONS=1536
AZURE_OPENAI_CHAT_DEPLOYMENT=<chat-deployment-name>

AZURE_AI_VISION_ENDPOINT=https://<vision-or-multiservice-resource>.cognitiveservices.azure.com/
AZURE_AI_VISION_API_KEY=<vision-api-key>
AZURE_AI_VISION_MODEL_VERSION=2023-04-15
AZURE_AI_VISION_EMBEDDING_DIMENSIONS=1024
AZURE_AI_VISION_TIMEOUT_SECONDS=300
